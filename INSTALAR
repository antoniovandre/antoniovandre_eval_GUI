if [ "${1}" == "desinstalar" ]; then echo -n "${TRABALHANDOESTATISTICAS} "; rm "${HOME}/antoniovandre_math_estatisticas.txt" &>> /dev/null; echo -e "${AV_VERDE}Ok${AV_SEMCOR}."; fi

