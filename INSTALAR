PYTHONNAOENCONTRADO=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '9p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '9p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

TCLTKNAOENCONTRADO=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '10p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '10p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

INSTALEDODIRETORIO=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '11p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '11p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

