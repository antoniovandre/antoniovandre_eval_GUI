TRABALHANDOEM=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '13p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '13p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

