#!/bin/bash

# Projeto Mathematical Ramblings (mathematicalramblings.blogspot.com).

# Script para compilar e instalar antoniovandre_eval_gui, versão de distribuição.

# Licença: Atribuição-NãoComercial-CompartilhaIgual (CC BY-NC-SA).

# Última atualização: 17-07-2020.

SOURCEDIR="Math/"
DESTDIR="/usr/bin/"
DESTDIRSHARE="/usr/share/"

if ! [ -n "$AVCORES" ]; then echo -ne "Carregando antoniovandre_cores... "; if ! source "antoniovandre_cores" &>> /dev/null; then echo -e "Ocorreu um erro.\n"; else echo -e "${AV_VERDE}Ok${AV_SEMCOR}.\n"; fi; fi

if [ "${1}" != "desinstalar" ] && [ "${1}" != "instalar" ]; then echo -e "${AV_VERMELHO}Entre com um dos argumentos: \"instalar\" ou \"desinstalar\"${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && hash antoniovandre_eval_gui &>> /dev/null; then echo -e "${AV_VERMELHO}Instalação anterior já realizada${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && hash antoniovandre_eval &>> /dev/null; then echo -e "${AV_VERMELHO}\"antoniovandre_eval\" em conflito${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "desinstalar" ] && ! hash antoniovandre_eval_gui &>> /dev/null; then echo -e "${AV_VERMELHO}Software já desinstalado${AV_SEMCOR}."; exit 1; fi

if ! hash bash &>> /dev/null; then echo -e "${AV_VERMELHO}Software \"bash\" não encontrado${AV_SEMCOR}."; exit 1; fi

if ! hash gcc &>> /dev/null; then echo -e "${AV_VERMELHO}Software \"gcc\" não encontrado${AV_SEMCOR}."; exit 1; fi

if ! hash md5sum &>> /dev/null; then echo -e "${AV_VERMELHO}Software \"md5sum\" não encontrado${AV_SEMCOR}."; exit 1; fi

if ! hash python3 &>> /dev/null; then echo -e "${AV_VERMELHO}Software \"python3\" não encontrado${AV_SEMCOR}."; exit 1; fi

if ! ls INSTALAR &>> /dev/null; then echo -e "${AV_VERMELHO}Instale a partir do diretório dos arquivos${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ]; then if ! ls README.txt &>> /dev/null || ! ls README.md &>> /dev/null || ! ls antoniovandre.c &>> /dev/null || ! ls antoniovandre_constantes.c &>> /dev/null || ! ls antoniovandre_eval_gui.py &>> /dev/null || ! ls antoniovandre_cores &>> /dev/null || ! ls antoniovandre_sobre.txt &>> /dev/null || ! ls antoniovandre_precisao_real.txt &>> /dev/null || ! ls Math/antoniovandre_eval.c &>> /dev/null || ! ls antoniovandre_eval_gui_bgimage.png &>> /dev/null || ! ls antoniovandre_eval_gui_logo.png &>> /dev/null || ! ls antoniovandre_eval_gui_logo_200p.png &>> /dev/null || [ "$(md5sum README.txt 2>> /dev/null | cut -d ' ' -f 1)" != "354ccc704dbec7d756848e3340004249" ] || [ "$(md5sum README.md 2>> /dev/null | cut -d ' ' -f 1)" != "73d4ef6dbb9cf8ebdd1840a0007db878" ] || [ "$(md5sum antoniovandre.c 2>> /dev/null | cut -d ' ' -f 1)" != "82afbb860a9fdd4531b1acb68861d913" ] || [ "$(md5sum antoniovandre_constantes.c 2>> /dev/null | cut -d ' ' -f 1)" != "f51aa177990b0a7fbfee03eb3041054a" ] || [ "$(md5sum antoniovandre_eval_gui.py 2>> /dev/null | cut -d ' ' -f 1)" != "106dfda7acf40eba6c3eb762995713e7" ] || [ "$(md5sum antoniovandre_cores 2>> /dev/null | cut -d ' ' -f 1)" != "d4f1a5742145b4d790698eed8eaf7d50" ] || [ "$(md5sum antoniovandre_sobre.txt 2>> /dev/null | cut -d ' ' -f 1)" != "4953fde4128437780c7898ebe7b47ef3" ] || [ "$(md5sum antoniovandre_precisao_real.txt 2>> /dev/null | cut -d ' ' -f 1)" != "d268edba3f2644172d611aa9bc7a43a9" ] || [ "$(md5sum Math/antoniovandre_eval.c 2>> /dev/null | cut -d ' ' -f 1)" != "c44c02132e0b983beee9bc0350202048" ] || [ "$(md5sum antoniovandre_eval_gui_bgimage.png 2>> /dev/null | cut -d ' ' -f 1)" != "89cb7026063ee5e52291ede3d75d730d" ] || [ "$(md5sum antoniovandre_eval_gui_logo.png 2>> /dev/null | cut -d ' ' -f 1)" != "a7fcaccb1a993d65a644d781b4fa8d59" ] || [ "$(md5sum antoniovandre_eval_gui_logo_200p.png 2>> /dev/null | cut -d ' ' -f 1)" != "77d3ec93b5775b1029c6099ed6421b20" ]; then echo -e "${AV_VERMELHO}Diretório corrompido${AV_SEMCOR}."; exit 1; fi; fi

echo -e "Certifique-se de que esteja executando este script com ${AV_AMARELO}privilégios de escrita${AV_SEMCOR} em \"${PWD}\", \"${PWD}/${SOURCEDIR}\", \"${DESTDIR}\", e em \"${DESTDIRSHARE}\". Vocẽ pode, como um conselho, se já não o fez, executar através do comando \"${AV_AMARELO}sudo${AV_SEMCOR}\".\n\nPressione ENTER para continuar. ou CTRL+C para abortar."; read;

if [ "${1}" == "instalar" ]; then echo -e "#define ARQUIVO_MATH_ESTATISTICAS \"${HOME}/antoniovandre_math_estatisticas.txt\"\n" > antoniovandre_extra.c; fi

DIR="${PWD}"
cd "${SOURCEDIR}"

OLDIFS="${IFS}"
IFS=$'\n'

for FILE in `ls -1 *.c`; do echo -ne "Trabalhando em \"${FILE}\"... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIR}${FILE%%.*}" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else if gcc "${FILE}" -o "${FILE%%.*}" -lm &>> /dev/null; then if mv "${FILE%%.*}" "${DESTDIR}" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; fi; done

IFS="${OLDIFS}"

cd .. &>> /dev/null

rm antoniovandre_extra.c &>> /dev/null

echo -n "Trabalhando no arquivo Python... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIR}antoniovandre_eval_gui.py" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else if cp antoniovandre_eval_gui.py ${DESTDIR} &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; fi

echo -n "Trabalhando no arquivo sobre... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIRSHARE}antoniovandre_sobre.txt" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else if cp antoniovandre_sobre.txt ${DESTDIRSHARE} &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; fi

echo -n "Trabalhando no arquivo de precisão real... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIRSHARE}antoniovandre_precisao_real.txt" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else if cp antoniovandre_precisao_real.txt ${DESTDIRSHARE} &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; fi

echo -n "Trabalhando no arquivo bgimage... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIRSHARE}antoniovandre_eval_gui_bgimage.png" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else if cp antoniovandre_eval_gui_bgimage.png ${DESTDIRSHARE} &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; fi

echo -n "Trabalhando no script executável... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIR}antoniovandre_eval_gui" &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; else if echo -e "#!/bin/bash\nDIR=\$PWD\ncd \"${HOME}\"\npython3 ${DESTDIR}antoniovandre_eval_gui.py\ncd \"\${DIR}\"\n" > antoniovandre_eval_gui && chmod a+x antoniovandre_eval_gui &>> /dev/null && mv antoniovandre_eval_gui ${DESTDIR} &>> /dev/null; then echo -e "${AV_VERDE}Sucesso${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}Ocorreu uma falha${AV_SEMCOR}."; exit 1; fi; fi

if [ "${1}" == "desinstalar" ]; then echo -n "Trabalhando no arquivo de estatísticas... "; rm "${HOME}/antoniovandre_math_estatisticas.txt" &>> /dev/null; echo -e "${AV_VERDE}Ok${AV_SEMCOR}."; fi

if [ "${1}" == "desinstalar" ]; then echo -e "\n${AV_VERDE}Sucesso${AV_SEMCOR} ao desinstalar."; else echo -e "\n${AV_VERDE}Sucesso${AV_SEMCOR} ao compilar e por os arquivos nos paths. O executável resultante é \"${AV_AMARELO}antoniovandre_eval_gui${AV_SEMCOR}\"."; fi

cd "${DIR}"

