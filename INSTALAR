TRABALHANDOEXECUTAVEL=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '20p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '20p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

TRABALHANDOESTATISTICAS=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '21p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '21p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

SUCESSODESINSTALAR=$(eval echo "$(if [ ${ARGUMENTOLINGUISTICO} == 'en' ]; then sed -n '22p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 2; else sed -n '22p' < ${TRADUCOESARQUIVO} | cut -d '%' -f 1; fi)")

