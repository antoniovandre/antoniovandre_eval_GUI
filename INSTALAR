if [ "${1}" != "desinstalar" ] && [ "${1}" != "instalar" ]; then echo -e "${AV_VERMELHO}${ENTRECOMOSARGUMENTOS}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && hash antoniovandre_eval_gui &>> /dev/null; then echo -e "${AV_VERMELHO}${JAINSTALADO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && hash antoniovandre_eval echo &>> /dev/null; then echo -e "${AV_VERMELHO}${CONFLITO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "desinstalar" ] && ! hash antoniovandre_eval_gui &>> /dev/null; then echo -e "${AV_VERMELHO}${JADESINSTALADO}${AV_SEMCOR}."; exit 1; fi

if ! hash bash &>> /dev/null; then echo -e "${AV_VERMELHO}${BASHNAOENCONTRADO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && ! hash gcc &>> /dev/null; then echo -e "${AV_VERMELHO}${GCCNAOENCONTRADO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && ! hash md5sum &>> /dev/null; then echo -e "${AV_VERMELHO}${MD5SUMNAOENCONTRADO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && ! hash python3 &>> /dev/null; then echo -e "${AV_VERMELHO}${PYTHONNAOENCONTRADO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && ! hash tclsh &>> /dev/null; then echo -e "${AV_VERMELHO}${TCLTKNAOENCONTRADO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ] && ! ls INSTALAR &>> /dev/null; then echo -e "${AV_VERMELHO}${INSTALEDODIRETORIO}${AV_SEMCOR}."; exit 1; fi

if [ "${1}" == "instalar" ]; then echo -e "${INSTALARINTRODUCAO}"; read; echo -e "#define ARQUIVO_MATH_ESTATISTICAS \"${HOME}/antoniovandre_math_estatisticas.txt\"\n" > antoniovandre_extra.c; fi

DIR="${PWD}"
cd "${SOURCEDIR}"

OLDIFS="${IFS}"
IFS=$'\n'

for FILE in `ls -1 *.c`; do echo -ne "${TRABALHANDOEM} \"${FILE}\"... "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIR}${FILE%%.*}" &>> /dev/null; then echo -e "${AV_VERDE}${SUCESSO}${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; exit 1; fi; else if gcc "${FILE}" -o "${FILE%%.*}" -lm &>> /dev/null; then if mv "${FILE%%.*}" "${DESTDIR}" &>> /dev/null; then echo -e "${AV_VERDE}${SUCESSO}${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; rm antoniovandre_extra.c &>> /dev/null; exit 1; fi; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; rm antoniovandre_extra.c &>> /dev/null; exit 1; fi; fi; done

IFS="${OLDIFS}"

cd .. &>> /dev/null

rm antoniovandre_extra.c &>> /dev/null

echo -n "${TRABALHANDOPYTHON} "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIR}antoniovandre_eval_gui.py" &>> /dev/null; then echo -e "${AV_VERDE}${SUCESSO}${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; exit 1; fi; else if cp antoniovandre_eval_gui.pytemp antoniovandre_eval_gui.pytempt && sed -i -e "s/ENTREEXPRESSAOCLIQUE/${ENTREEXPRESSAOCLIQUE}/g" antoniovandre_eval_gui.pytempt && sed -i -e "s/RESULTADO/${RESULTADO}/g" antoniovandre_eval_gui.pytempt && sed -i -e "s/ENTREEXPRESSAO/${ENTREEXPRESSAO}/g" antoniovandre_eval_gui.pytempt && sed -i -e "s/MAJUDA/${MAJUDA}/g" antoniovandre_eval_gui.pytempt && sed -i -e "s/CALCULAR/${CALCULAR}/g" antoniovandre_eval_gui.pytempt && sed -i -e "s/AJUDA/${AJUDA}/g" antoniovandre_eval_gui.pytempt && sed -i -e "s/SAIR/${SAIR}/g" antoniovandre_eval_gui.pytempt && mv antoniovandre_eval_gui.pytempt "${DESTDIR}antoniovandre_eval_gui.py" &>> /dev/null; then echo -e "${AV_VERDE}${SUCESSO}${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; rm antoniovandre_eval_gui.pytempt &>> /dev/null; exit 1; fi; fi

echo -n "${TRABALHANDOSOBRE} "; if [ "${1}" == "desinstalar" ]; then if rm "${DESTDIRSHARE}antoniovandre_sobre.txt" &>> /dev/null; then echo -e "${AV_VERDE}${SUCESSO}${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; exit 1; fi; else if cp "${ARQUIVOSOBRE}" "${DESTDIRSHARE}antoniovandre_sobre.txt" &>> /dev/null; then echo -e "${AV_VERDE}${SUCESSO}${AV_SEMCOR}."; else echo -e "${AV_VERMELHO}${OCORREUFALHA}${AV_SEMCOR}."; exit 1; fi; fi

